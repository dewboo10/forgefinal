# Copy this to .env and fill in your values
VITE_API_URL=http://localhost:3001
VITE_BOT_URL=http://localhost:3000
VITE_TON_NETWORK=mainnet

# Your TON wallet address — this is where store payments get sent
# Get it from Tonkeeper or any TON wallet (starts with UQ or EQ)
VITE_TON_ADDRESS=your_ton_wallet_address_here

# Your deployed frontend URL — used for TonConnect manifest and TON address verification
VITE_APP_URL=https://your-frontend-domain.com
